{
  "name": "med-analiz",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "npm@10.8.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "lint": "eslint .",
    "format": "prettier --check \"**/*.{js,json,ts,yml,yaml}\" \"docs/stage-1-architecture.md\" \"infra/**/*.md\"",
    "format:write": "prettier --write \"**/*.{js,json,ts,yml,yaml}\" \"docs/stage-1-architecture.md\" \"infra/**/*.md\"",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "check": "npm run lint && npm run format && npm run typecheck && npm run test"
  },
  "devDependencies": {
    "@eslint/js": "9.14.0",
    "@types/node": "22.9.0",
    "eslint": "9.14.0",
    "globals": "15.12.0",
    "prettier": "3.3.3",
    "typescript": "5.6.3",
    "typescript-eslint": "8.13.0",
    "vitest": "2.1.4"
  }
}
