APP_ENV=dev
DATABASE_URL=postgresql://med_analiz:med_analiz@postgres:5432/med_analiz
REDIS_URL=redis://redis:6379
S3_ENDPOINT=http://minio:9000
S3_BUCKET_ORIGINALS=med-analiz-originals
S3_BUCKET_DERIVED=med-analiz-derived
TLS_TERMINATION=local-dev
FILE_ENCRYPTION_MODE=aes-256-managed
ADMIN_2FA_REQUIRED=true
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCK_MINUTES=15
ANTIVIRUS_PROVIDER=stub-clean
