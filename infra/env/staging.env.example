APP_ENV=staging
DATABASE_URL=postgresql://<user>:<password>@<host>:5432/<database>
REDIS_URL=redis://<host>:6379
S3_ENDPOINT=https://<s3-compatible-endpoint>
S3_REGION=<region>
S3_BUCKET_ORIGINALS=<originals-bucket>
S3_BUCKET_DERIVED=<derived-bucket>
S3_ACCESS_KEY_ID=<secret-manager-ref>
S3_SECRET_ACCESS_KEY=<secret-manager-ref>
JWT_SECRET=<secret-manager-ref>
